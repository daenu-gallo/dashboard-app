# Supabase Configuration
# Get these from your Supabase project settings (or Coolify environment)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Upload-API (Bilder auf NAS)
VITE_UPLOAD_API_URL=http://your-server:3200

# Shop – Print Provider API Keys
# Gelato: https://dashboard.gelato.com → Settings → API Keys
GELATO_API_KEY=your-gelato-api-key
# nPhoto: https://nphoto.ch → Kontakt für API-Zugang
NPHOTO_API_KEY=your-nphoto-api-key
